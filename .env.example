# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# NODE CONFIGURATION (required for every server)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

NODE_ID=node-1
# Unique name for this server instance. Used in logs, cluster membership, and gossip routing.
# Change on each machine (node-1, node-2, node-3, etc).
# Must contain only letters, numbers, and hyphens.

NODE_PORT=18861
# Port this server listens on for incoming RPC requests from clients and other servers.
# Must be open in your firewall. If running multiple nodes on one machine,
# use different ports (18861, 18862, 18863 for a 3-node cluster).

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CLUSTER CONFIGURATION (same on all servers)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

ETCD_HOST=localhost
# IP address or hostname where etcd is running.
# In Docker: use service name "etcd" (Docker DNS resolves it).
# On your machine: use "localhost" or "127.0.0.1".

ETCD_PORT=2379
# Port etcd listens on. Default is 2379. Change only if you configured etcd differently.

CLUSTER_NAME=mmoney-cluster
# Logical name for this cluster. All nodes in the same cluster must use the same name.
# Useful if you have multiple independent clusters on the same etcd instance.

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# GEOGRAPHIC LOCATION (optional, speeds up server discovery)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

MMONEY_LAT=
# Your server's latitude in decimal degrees (e.g., 51.5 for London).
# Leave blank to auto-detect from this machine's public IP address
# (adds ~500ms to startup but only runs once per 24 hours).
# Find your latitude at https://www.latlong.net/

MMONEY_LON=
# Your server's longitude in decimal degrees (e.g., -0.1 for London).
# Required only if MMONEY_LAT is set.

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# LOGGING AND DEBUGGING
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

LOG_LEVEL=INFO
# Set to DEBUG for verbose output (shows network packets, gossip rounds, etc).
# Set to INFO for normal operation (only significant events).
# Set to WARNING to see only errors (not recommended — you'll miss important info).

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CERTIFICATES (for TLS encryption)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

CERT_FILE=certs/node-1/cert.pem
# Path to this node's TLS certificate file.
# Generate with: bash certs/gen_certs.sh node-1

KEY_FILE=certs/node-1/key.pem
# Path to this node's private key file.
# NEVER share this file. Protect it like a password.

CA_CERT_FILE=certs/ca.pem
# Path to the Certificate Authority's public certificate.
# All nodes must trust this CA to validate each other's certificates.
